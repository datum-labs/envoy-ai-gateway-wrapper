# ---------------------------------------------------------------------------
# Envoy AI Gateway – Observability Console
#
# ALL of these are OPTIONAL. With none set, the console runs in "demo" mode
# using deterministic sample data, so it deploys and works out of the box.
# Set them to point the console at a real Envoy AI Gateway deployment.
# Copy this file to `.env.local` for local dev.
# ---------------------------------------------------------------------------

# Base URL of your Envoy AI Gateway (OpenAI-compatible endpoint).
# When set, the console switches from demo mode to "live" mode and proxies
# Playground chat requests through this gateway.
# Example: https://gateway.your-domain.com
ENVOY_AI_GATEWAY_URL=

# Bearer token used to authenticate against the gateway above.
# Sent as `Authorization: Bearer <key>` on gateway + metrics requests.
ENVOY_AI_GATEWAY_API_KEY=

# Optional override for the Prometheus metrics endpoint that powers the
# dashboard charts. If omitted, the console scrapes `${ENVOY_AI_GATEWAY_URL}/metrics`.
# Example: https://gateway.your-domain.com/metrics
ENVOY_AI_GATEWAY_METRICS_URL=
